{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/server.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/server.mjs" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/brand/(.*)", "dest": "/brand/$1" },
    { "src": "/theme.css", "dest": "/theme.css" },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "^/([^/]+\\.(?:css|js|json|ico|svg|png|jpg|jpeg|webp|avif|woff|woff2|ttf|mp4|webm))$", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}